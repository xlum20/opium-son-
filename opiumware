EOF
echo -e "${NC}"
echo -e "${BLUE}=[ Opiumware (Intel) Installer ]=${NC}"
echo -e "${CYAN}Developed by @norbyv1 | Fixed build by trial support king dior${NC}"
[[ "$DEBUG" -eq 1 ]] && warn "Debug mode ON"

step "Fetching latest URLs"
REMOTE_INST="$(curl -fsSL https://raw.githubusercontent.com/norbyv1/OpiumwareInstall/main/inst)" \
    || fail "Could not reach update server"
DYLIB_URL="$(echo "$REMOTE_INST"   | grep -m1 '^DYLIB_URL='   | cut -d'"' -f2)"
MODULES_URL="$(echo "$REMOTE_INST" | grep -m1 '^MODULES_URL=' | cut -d'"' -f2)"
[[ -n "$DYLIB_URL" ]]   || fail "Could not parse DYLIB_URL"
[[ -n "$MODULES_URL" ]] || fail "Could not parse MODULES_URL"
ok "URLs loaded"

MACOS_MAJOR="$(sw_vers -productVersion | awk -F. '{print $1}')"
if [[ "$MACOS_MAJOR" -le 11 ]]; then
    UI_URL="$UI_URL_LEGACY"
    info "macOS $MACOS_MAJOR detected — using Legacy UI automatically"
else
    echo
    echo -e "${BOLD}Would you like to use the Old UI (Legacy)?${NC}"
    echo -e "  ${GREEN}[Y]${NC} Yes — install Legacy UI"
    echo -e "  ${CYAN}[N]${NC} No  — install latest UI  ${YELLOW}(recommended)${NC}"
    echo
    read -rp "$(echo -e "${BOLD}Choice [Y/N]: ${NC}")" UI_CHOICE </dev/tty
    UI_CHOICE_UPPER="$(echo "$UI_CHOICE" | tr '[:lower:]' '[:upper:]')"
    case "$UI_CHOICE_UPPER" in
        Y|YES)
            UI_URL="$UI_URL_LEGACY"
            echo -e "${CHECK} Using ${YELLOW}Legacy UI${NC}"
            ;;
        N|NO|"")
            UI_URL="$UI_URL_NEW"
            echo -e "${CHECK} Using ${GREEN}Latest UI${NC}"
            ;;
        *)
            warn "Unrecognised input — defaulting to Latest UI"
            UI_URL="$UI_URL_NEW"
            ;;
    esac
fi

if [ -w "/Applications" ]; then
    APP_DIR="/Applications"
else
    APP_DIR="$HOME/Applications"
    mkdir -p "$APP_DIR"
    warn "No write access to /Applications — using $APP_DIR"
fi

TEMP="$(mktemp -d)"

cleanup() {
    local code=$?
    [[ $code -ne 0 ]] && echo -e "\n${RED}${BOLD}Installation failed (exit $code)${NC}" && warn "Temp dir kept: $TEMP" && return
    rm -rf "$TEMP"
}
trap cleanup EXIT

killall -9 RobloxPlayer Opiumware &>/dev/null || true

for target in "$APP_DIR/Roblox.app" "$APP_DIR/Opiumware.app"; do
    if [ -e "$target" ]; then
        rm -rf "$target" 2>/dev/null \
            || sudo rm -rf "$target" 2>/dev/null \
            || fail "Could not remove $target — delete it manually and rerun"
    fi
done

rm -rf ~/Opiumware/modules/LuauLSP ~/Opiumware/modules/decompiler
rm -f ~/Opiumware/modules/update.json 2>/dev/null || true

step "Fetching client version"
VERSION="version-0b2afd6436e74a1f"
info "Version: ${BOLD}$VERSION${NC}"

MIMALLOC="$APP_DIR/Roblox.app/Contents/MacOS/libmimalloc.3.dylib"

step "Downloading..."
curl -fsSL "https://setup.rbxcdn.com/mac/$VERSION-RobloxPlayer.zip" -o "$TEMP/RobloxPlayer.zip" || fail "RobloxPlayer.zip download failed — version $VERSION may be outdated"
curl -fsSL "$DYLIB_URL"   -o "$TEMP/libOpiumware.zip" || fail "libOpiumware.zip download failed"
curl -fsSL "$MODULES_URL" -o "$TEMP/modules.zip"      || fail "modules.zip download failed"
curl -fsSL "$UI_URL"      -o "$TEMP/OpiumwareUI.zip"  || fail "OpiumwareUI.zip download failed"
ok "Downloading... - Completed"

step "Installing Opiumware modules"
(
    unzip -oq "$TEMP/RobloxPlayer.zip" -d "$TEMP"
    mv "$TEMP/RobloxPlayer.app" "$APP_DIR/Roblox.app"
    strip_quarantine "$APP_DIR/Roblox.app"

    unzip -oq "$TEMP/libOpiumware.zip" -d "$TEMP"
    mv "$TEMP/libOpiumware.dylib" "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib"

    unzip -oq "$TEMP/modules.zip" -d "$TEMP"
    chmod +x "$TEMP/Resources/Injector"
    "$TEMP/Resources/Injector" \
        "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib" \
        "$MIMALLOC" \
        --strip-codesig --all-yes >/dev/null 2>&1
    mv "${MIMALLOC}_patched" "$MIMALLOC"

    sign_target "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib"
    sign_target "$MIMALLOC"
    rm -rf "$APP_DIR/Roblox.app/Contents/MacOS/RobloxPlayerInstaller.app" 2>/dev/null || true
    sign_target "$APP_DIR/Roblox.app" --deep
    tccutil reset Accessibility com.Roblox.RobloxPlayer >/dev/null 2>&1 || true

    unzip -oq "$TEMP/OpiumwareUI.zip" -d "$TEMP"
    mv -f "$TEMP/Opiumware.app" "$APP_DIR/Opiumware.app"
    sign_target "$APP_DIR/Opiumware.app" --deep
    mkdir -p ~/Opiumware/workspace ~/Opiumware/autoexec ~/Opiumware/themes \
             ~/Opiumware/modules ~/Opiumware/modules/decompiler ~/Opiumware/modules/LuauLSP
    mv -f "$TEMP/Resources/decompiler" ~/Opiumware/modules/decompiler/Decompiler
    mv -f "$TEMP/Resources/LuauLSP"    ~/Opiumware/modules/LuauLSP/LuauLSP
    tccutil reset ScreenCapture com.norbyv1.opiumware >/dev/null 2>&1 || true

    cat > ~/Opiumware/autoexec/loadingfix.lua << 'LUAEOF'
if not game:IsLoaded() then
   game.Loaded:Wait()
end
LUAEOF

    touch ~/Opiumware/autoexec/blank.lua

    PLIST="$APP_DIR/Roblox.app/Contents/Info.plist"
    if [[ -f "$PLIST" ]]; then
        plutil -replace CFBundleExecutable -string "RobloxPlayer" "$PLIST" 2>/dev/null || true
    fi

    LAUNCHER="$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher"
    if [[ -f "$LAUNCHER" ]]; then
        mv -f "$LAUNCHER" "$LAUNCHER.bak" 2>/dev/null || true
    fi
    cat > "$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher" << 'SHEOF'
#!/usr/bin/env bash
exec "$(dirname "$0")/RobloxPlayer" "$@"
SHEOF
    chmod +x "$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher"
) & spinner "Installing" $!

if [[ "$DEBUG" -eq 1 ]]; then
    step "Debug: signature report"
    for f in \
        "$APP_DIR/Roblox.app/Contents/MacOS/RobloxPlayer" \
        "$MIMALLOC" \
        "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib" \
        "$APP_DIR/Opiumware.app"
    do
        echo -e "${INFO} $(basename "$f")"
        codesign -dvv "$f" 2>&1 | sed "s/^/  /"
    done
fi

echo
echo -e "${GREEN}${BOLD}Installation complete.${NC}"
warn "Please use an alt account."
open "$APP_DIR/Roblox.app"
open "$APP_DIR/Opiumware.app"
