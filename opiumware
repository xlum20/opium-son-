#!/usr/bin/env bash

# Opiumware Combined Installer
# Base by @norbyv1 | Fixed build by trial support king dior

set -euo pipefail
IFS=$'\n\t'

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

CHECK="${GREEN}✔${NC}"
CROSS="${RED}✖${NC}"
INFO="${CYAN}➜${NC}"
WARN="${YELLOW}⚠${NC}"

UI_URL_NEW="https://q3p1xj20dh.ufs.sh/f/BrzckOVD7pCZXic4yblOrXx5SwcQKWkvE8P629ny4DmGCYVA"
UI_URL_LEGACY="https://x099xkycxe.ufs.sh/f/ar75CUBjeUn973Un5SgiSg2Cb3OUYDHqn5ozMk0fmAtRrcsx"

DEBUG=0
[[ "${1:-}" == "--debug" ]] && DEBUG=1

dbg()  { [[ "$DEBUG" -eq 1 ]] && echo -e "${YELLOW}[DBG]${NC} $*" || true; }
step() { echo -e "\n${BOLD}${CYAN}==> $1${NC}"; }
ok()   { echo -e "${CHECK} $1"; }
info() { echo -e "${INFO} $1"; }
warn() { echo -e "${WARN} $1"; }
fail() { echo -e "${CROSS} ${RED}$1${NC}"; exit 1; }

spinner() {
    local msg="$1"
    local pid="$2"
    wait "$pid"
    printf "\r\033[K"
    printf "${GREEN}${CHECK} %s - Completed${NC}\n" "$msg"
}

strip_quarantine() {
    local target="$1"
    xattr -cr "$target" 2>/dev/null || \
        find "$target" -exec xattr -d com.apple.quarantine {} \; 2>/dev/null || true
}

sign_target() {
    local target="$1"
    local deep="${2:-}"
    if [[ "$deep" == "--deep" ]]; then
        codesign --force --deep --sign - "$target" 2>/dev/null && return 0
        codesign --force --deep --sign - --preserve-metadata=identifier,entitlements "$target" 2>/dev/null && return 0
    else
        codesign --force --sign - "$target" 2>/dev/null && return 0
        codesign --force --sign - --preserve-metadata=identifier,entitlements "$target" 2>/dev/null && return 0
    fi
    fail "codesign failed on $(basename "$target")"
}

clear
echo -e "${BOLD}"
cat <<'EOF'
