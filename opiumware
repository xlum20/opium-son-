#!/usr/bin/env bash

# Opiumware Combined Installer
# Base by @norbyv1 | Fixed build by trial support king dior

set -euo pipefail
IFS=$'\n\t'

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PINK='\033[1;35m'
BOLD='\033[1m'
NC='\033[0m'

CHECK="${PINK}✔${NC}"
CROSS="${RED}✖${NC}"
INFO="${PINK}➜${NC}"
WARN="${PINK}⚠${NC}"

UI_URL_NEW=""
UI_URL_LEGACY=""

DEBUG=0
[[ "${1:-}" == "--debug" ]] && DEBUG=1

dbg()  { [[ "$DEBUG" -eq 1 ]] && echo -e "${YELLOW}[DBG]${NC} $*" || true; }
step() { echo -e "\n${BOLD}${PINK}==> $1${NC}"; }
ok()   { echo -e "${CHECK} $1"; }
info() { echo -e "${INFO} $1"; }
warn() { echo -e "${WARN} $1"; }
fail() { echo -e "${CROSS} ${RED}$1${NC}"; exit 1; }

spinner() {
    local msg="$1"
    local pid="$2"
    wait "$pid"
    printf "\r\033[K"
    printf "${GREEN}${CHECK} %s - Completed${NC}\n" "$msg"
}

strip_quarantine() {
    local target="$1"
    xattr -cr "$target" 2>/dev/null || \
        find "$target" -exec xattr -d com.apple.quarantine {} \; 2>/dev/null || true
}

sign_target() {
    local target="$1"
    local deep="${2:-}"
    if [[ "$deep" == "--deep" ]]; then
        codesign --force --deep --sign - "$target" 2>/dev/null && return 0
        codesign --force --deep --sign - --preserve-metadata=identifier,entitlements "$target" 2>/dev/null && return 0
    else
        codesign --force --sign - "$target" 2>/dev/null && return 0
        codesign --force --sign - --preserve-metadata=identifier,entitlements "$target" 2>/dev/null && return 0
    fi
    fail "codesign failed on $(basename "$target")"
}

clear
echo -e "${BOLD}"
cat <<'EOF'
                            ╱|、
                          (˚ˎ 。7  
                           |、˜〵          
                          じしˍ,)ノ
                          the xperiment | opiumware
EOF
echo -e "${NC}"
echo -e "${PINK}=[ Opium-Chan Installer ]=${NC}"
echo -e "${PINK}Developed by @norbyv1 | Fixed build by the bestsupport king dior-chan  v0.3 ${NC}"
[[ "$DEBUG" -eq 1 ]] && warn "Debug mode ON"

step "Fetching latest URLs"
REMOTE_INST="$(curl -fsSL https://raw.githubusercontent.com/norbyv1/OpiumwareInstall/refs/heads/main/inst)" \
    || fail "Could not reach update server"
REMOTE_LEGACY="$(curl -fsSL https://raw.githubusercontent.com/norbyv1/OpiumwareInstall/refs/heads/main/legacyinst)" \
    || fail "Could not reach legacy update server"
DYLIB_URL="$(echo "$REMOTE_INST"   | grep -m1 '^DYLIB_URL='   | cut -d'"' -f2)"
MODULES_URL="$(echo "$REMOTE_INST" | grep -m1 '^MODULES_URL=' | cut -d'"' -f2)"
UI_URL_NEW="$(echo "$REMOTE_INST"  | grep -m1 '^UI_URL='      | cut -d'"' -f2)"
UI_URL_LEGACY="$(echo "$REMOTE_LEGACY" | grep -m1 '^UI_URL='  | cut -d'"' -f2)"
[[ -n "$DYLIB_URL" ]]    || fail "Could not parse DYLIB_URL"
[[ -n "$MODULES_URL" ]]  || fail "Could not parse MODULES_URL"
[[ -n "$UI_URL_NEW" ]]   || fail "Could not parse UI_URL from inst"
[[ -n "$UI_URL_LEGACY" ]] || fail "Could not parse UI_URL from legacyinst"
ok "URLs loaded"

MACOS_MAJOR="$(sw_vers -productVersion | awk -F. '{print $1}')"
if [[ "$MACOS_MAJOR" -le 11 ]]; then
    UI_URL="$UI_URL_LEGACY"
    info "macOS $MACOS_MAJOR detected — using Legacy UI automatically"
else
    echo
    echo -e "${BOLD}Which UI would you like to use? ?${NC}"
    echo -e "  ${GREEN}[Y]${NC} Y - install Legacy UI"
    echo -e "  ${CYAN}[N]${NC} No - install latest UI  ${YELLOW}(recommended)${NC}"
    echo
    read -rp "$(echo -e "${BOLD}Choice [Y/N]: ${NC}")" UI_CHOICE </dev/tty
    UI_CHOICE_UPPER="$(echo "$UI_CHOICE" | tr '[:lower:]' '[:upper:]')"
    case "$UI_CHOICE_UPPER" in
        Y|YES)
            UI_URL="$UI_URL_LEGACY"
            echo -e "${CHECK} Using ${YELLOW}Legacy UI${NC}"
            ;;
        N|NO|"")
            UI_URL="$UI_URL_NEW"
            echo -e "${CHECK} Using ${GREEN}Latest UI${NC}"
            ;;
        *)
            warn "Unrecognised input — defaulting to Latest UI"
            UI_URL="$UI_URL_NEW"
            ;;
    esac
fi

if [ -w "/Applications" ]; then
    APP_DIR="/Applications"
else
    APP_DIR="$HOME/Applications"
    mkdir -p "$APP_DIR"
    warn "No write access to /Applications — using $APP_DIR"
fi

TEMP="$(mktemp -d)"

cleanup() {
    local code=$?
    [[ $code -ne 0 ]] && echo -e "\n${RED}${BOLD}Installation failed (exit $code)${NC}" && warn "Temp dir kept: $TEMP" && return
    rm -rf "$TEMP"
}
trap cleanup EXIT

killall -9 RobloxPlayer Opiumware &>/dev/null || true

for target in "$APP_DIR/Roblox.app" "$APP_DIR/Opiumware.app"; do
    if [ -e "$target" ]; then
        rm -rf "$target" 2>/dev/null \
            || sudo rm -rf "$target" 2>/dev/null \
            || fail "Could not remove $target — delete it manually and rerun"
    fi
done

rm -rf ~/Opiumware/modules/LuauLSP ~/Opiumware/modules/decompiler
rm -f ~/Opiumware/modules/update.json 2>/dev/null || true

step "Fetching client version"
VERSION="$(echo "$REMOTE_INST" | grep -m1 '^version=' | cut -d'"' -f2)"
[[ -n "$VERSION" ]] || fail "Could not parse version from inst"
info "Version: ${BOLD}$VERSION${NC}"

MIMALLOC="$APP_DIR/Roblox.app/Contents/MacOS/libmimalloc.3.dylib"

step "Downloading..."
curl -fsSL --parallel --parallel-immediate \
    "https://setup.rbxcdn.com/mac/$VERSION-RobloxPlayer.zip" -o "$TEMP/RobloxPlayer.zip" \
    "$DYLIB_URL"   -o "$TEMP/libOpiumware.zip" \
    "$MODULES_URL" -o "$TEMP/modules.zip" \
    "$UI_URL"      -o "$TEMP/OpiumwareUI.zip" \
    || fail "One or more downloads failed"
ok "Downloading... - Completed"

step "Installing Opiumware modules"
(
    unzip -oq "$TEMP/RobloxPlayer.zip" -d "$TEMP"
    unzip -oq "$TEMP/libOpiumware.zip" -d "$TEMP" &
    unzip -oq "$TEMP/modules.zip" -d "$TEMP" &
    wait
    mv "$TEMP/RobloxPlayer.app" "$APP_DIR/Roblox.app"
    strip_quarantine "$APP_DIR/Roblox.app"
    mv "$TEMP/libOpiumware.dylib" "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib"
    chmod +x "$TEMP/Resources/Injector"
    xattr -cr "$TEMP/Resources/Injector" 2>/dev/null || true
    codesign --force --sign - "$TEMP/Resources/Injector" 2>/dev/null || true
    "$TEMP/Resources/Injector" \
        "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib" \
        "$MIMALLOC" \
        --strip-codesig --all-yes >/dev/null 2>&1 || fail "Injector failed — try running installer as admin with sudo"
    mv "${MIMALLOC}_patched" "$MIMALLOC"

rm -rf "$APP_DIR/Roblox.app/Contents/MacOS/RobloxPlayerInstaller.app" 2>/dev/null || true
    unzip -oq "$TEMP/OpiumwareUI.zip" -d "$TEMP" &
    sign_target "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib" &
    sign_target "$MIMALLOC" &
    wait
    sign_target "$APP_DIR/Roblox.app" --deep
    command -v tccutil &>/dev/null && tccutil reset Accessibility com.Roblox.RobloxPlayer >/dev/null 2>&1 || true
    mv -f "$TEMP/Opiumware.app" "$APP_DIR/Opiumware.app"
    sign_target "$APP_DIR/Opiumware.app" --deep
    mkdir -p ~/Opiumware/workspace ~/Opiumware/autoexec ~/Opiumware/themes \
             ~/Opiumware/modules ~/Opiumware/modules/decompiler ~/Opiumware/modules/LuauLSP
    cp -f "$TEMP/Resources/decompiler" ~/Opiumware/modules/decompiler/Decompiler 2>/dev/null || \
    cp -f "$TEMP/Resources/Decompiler" ~/Opiumware/modules/decompiler/Decompiler 2>/dev/null || true
    chmod +x ~/Opiumware/modules/decompiler/Decompiler 2>/dev/null || true
    mv -f "$TEMP/Resources/LuauLSP" ~/Opiumware/modules/LuauLSP/LuauLSP &
    wait
    command -v tccutil &>/dev/null && tccutil reset ScreenCapture com.norbyv1.opiumware >/dev/null 2>&1 || true

    cat > ~/Opiumware/autoexec/loadingfix.lua << 'LUAEOF'
if not game:IsLoaded() then
   game.Loaded:Wait()
end
LUAEOF

    touch ~/Opiumware/autoexec/blank.lua

    PLIST="$APP_DIR/Roblox.app/Contents/Info.plist"
    if [[ -f "$PLIST" ]]; then
        plutil -replace CFBundleExecutable -string "RobloxPlayer" "$PLIST" 2>/dev/null || true
    fi

    LAUNCHER="$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher"
    if [[ -f "$LAUNCHER" ]]; then
        mv -f "$LAUNCHER" "$LAUNCHER.bak" 2>/dev/null || true
    fi
    cat > "$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher" << 'SHEOF'
#!/usr/bin/env bash
exec "$(dirname "$0")/RobloxPlayer" "$@"
SHEOF
    chmod +x "$APP_DIR/Roblox.app/Contents/MacOS/RobloxLauncher"
) 2>&1 | tee "$TEMP/install.log" & spinner "Installing" $!
cat "$TEMP/install.log" 2>/dev/null || true

if [[ "$DEBUG" -eq 1 ]]; then
    step "Debug: signature report"
    for f in \
        "$APP_DIR/Roblox.app/Contents/MacOS/RobloxPlayer" \
        "$MIMALLOC" \
        "$APP_DIR/Roblox.app/Contents/Resources/libOpiumware.dylib" \
        "$APP_DIR/Opiumware.app"
    do
        echo -e "${INFO} $(basename "$f")"
        codesign -dvv "$f" 2>&1 | sed "s/^/  /"
    done
fi

echo
echo -e "${PINK}${BOLD}🐱 Installation complete, nya~ uwu!!${NC}"
warn "Please use an alt account."
open "$APP_DIR/Roblox.app"
open "$APP_DIR/Opiumware.app"
